generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String       @id @default(cuid())
  name                 String
  email                String       @unique
  password             String
  // Rollen: ka_admin, ka_gruppenführer, ka_mitarbeiter, baumschule, kunde
  role                 String       @default("mitarbeiter")
  avatar               String?
  active               Boolean      @default(true)
  deletedAt            DateTime? // Soft-Delete Timestamp (DSGVO Retention)
  // Sprint UX: Permissions & Benachrichtigungen
  permissions          String[]     @default([])
  lastLoginAt          DateTime?
  notifyMaengel        Boolean      @default(true)
  notifyAuftraege      Boolean      @default(true)
  notifyAbnahmen       Boolean      @default(false)
  // Sprint Q015: 2FA TOTP
  twoFactorSecret      String? // Base32-encoded TOTP secret (encrypted)
  twoFactorEnabled     Boolean      @default(false)
  twoFactorBackupCodes String[]     @default([]) // Hashed backup codes
  twoFactorVerifiedAt  DateTime? // When 2FA was first verified
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  sessions             Session[]
  mitarbeiter          Mitarbeiter?
  // Sprint AJ: Baumschul-Verknüpfung
  baumschule           Baumschule?
  // Sprint KB: Vertragsversionierung (AGB-Akzeptanz)
  agreements           UserAgreement[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Magic-Link Token für passwortlosen Login (Waldbesitzer)
model MagicToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Mitarbeiter {
  id                        String                     @id @default(cuid())
  userId                    String?                    @unique
  vorname                   String
  nachname                  String
  email                     String?
  telefon                   String?
  mobil                     String?
  adresse                   String?
  plz                       String?
  ort                       String?
  geburtsdatum              DateTime?
  eintrittsdatum            DateTime?
  austrittsdatum            DateTime?
  rolle                     String                     @default("mitarbeiter")
  qualifikationen           String?
  fuehrerschein             String?
  notfallkontakt            String?
  notfalltelefon            String?
  bankname                  String?
  iban                      String?
  stundenlohn               Float?
  status                    String                     @default("aktiv")
  notizen                   String?
  deletedAt                 DateTime? // Soft-Delete Timestamp (DSGVO Retention)
  vollkostenSatz            Float? // Überschreibt vollkosten_pro_stunde (Sprint Q)
  maschinenbonusIndividuell Float? // Überschreibt maschinenbonus_mitarbeiter (Sprint Q)
  notfallName               String? // Notfallkontakt Name (Sprint U)
  notfallTelefon            String? // Notfallkontakt Telefon (Sprint U)
  notfallBeziehung          String? // Notfallkontakt Beziehung z.B. Partner, Mutter (Sprint U)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  user                      User?                      @relation(fields: [userId], references: [id])
  gruppen                   GruppeMitglied[]
  saisonAnmeldungen         SaisonAnmeldung[]
  qualifikationenRel        MitarbeiterQualifikation[]
  schulungen                MitarbeiterSchulung[]
  stundeneintraege          Stundeneintrag[]
  lohneintraege             Lohneintrag[]
  vorschuesse               Vorschuss[]
  abwesenheiten             Abwesenheit[]
  lagerBewegungen           LagerBewegung[]
  lohnabrechnungen          Lohnabrechnung[]
  dokumente                 Dokument[]
}

model Saison {
  id               String            @id @default(cuid())
  name             String
  typ              String            @default("pflanzung")
  status           String            @default("planung")
  startDatum       DateTime?
  endDatum         DateTime?
  beschreibung     String?
  ziel             String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  anmeldungen      SaisonAnmeldung[]
  dokumente        Dokument[]
  gruppen          Gruppe[]
  auftraege        Auftrag[]
  lohnabrechnungen Lohnabrechnung[]
}

// ============================================================
// TENANT CHURN STATUS (Sprint OA IMPL-CHURN-01)
// Verwaltet Vertragslebenszyklen: aktiv → gekündigt → grace_period → archiviert
// ============================================================

enum TenantStatus {
  active         // Aktiver Vertrag, voller Zugriff
  cancelled      // Kündigung eingereicht, noch aktiv bis contractEndDate
  grace_period   // Vertrag ausgelaufen, 30 Tage Lesezugriff + Export
  archived       // Nach Grace Period: Steuerrelevante Daten archiviert, GPS gelöscht
  deleted        // Vollständig gelöscht (nur bei Nicht-Kunden ohne Daten)
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  primaryColor String   @default("#2C3A1C")
  domain       String?
  contactEmail String?  // Admin/Ansprechpartner E-Mail für Benachrichtigungen
  // Churn-Management (Sprint OA IMPL-CHURN-01)
  status           TenantStatus @default(active)
  contractEndDate  DateTime?    // Vertragsende (bei Kündigung gesetzt)
  graceEndDate     DateTime?    // Ende der Grace Period (contractEndDate + 30 Tage)
  archivedAt       DateTime?    // Wann wurde der Tenant archiviert
  cancelledAt      DateTime?    // Wann wurde die Kündigung eingereicht
  cancelledBy      String?      // User-ID der kündigenden Person
  cancellationNote String?      // Kündigungsgrund (optional)
  // Churn-Notification Tracking (Sprint OD)
  lastChurnNotifyAt DateTime?   // Letztes Datum einer Churn-Benachrichtigung
  lastChurnNotifyDays Int?      // Tage bis Sperre bei letzter Benachrichtigung
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  entityName String
  userId     String?
  metadata   String?
  createdAt  DateTime @default(now())
}

// AUFTRAG
model Auftrag {
  id                  String             @id @default(cuid())
  titel               String
  typ                 String
  status              String             @default("anfrage")
  beschreibung        String?
  flaeche_ha          Float?
  standort            String?
  bundesland          String?
  waldbesitzer        String?
  waldbesitzerEmail   String?
  waldbesitzerTelefon String?
  baumarten           String?
  zeitraum            String?
  notizen             String?
  nummer              String?            @unique // Auto-generiert: AU-YYYY-NNNN (Sprint Q)
  neuFlag             Boolean            @default(false)
  wpProjektId         String?            @unique
  wizardDaten         Json? // Kompletter ka_wizard_daten JSON aus WordPress
  saisonId            String?
  gruppeId            String?
  startDatum          DateTime?
  endDatum            DateTime?
  wpErstelltAm        DateTime? // Erstellungsdatum aus WP (ka_angelegt Unix-Timestamp)
  lat                 Float? // GPS-Koordinate Breitengrad (Sprint U)
  lng                 Float? // GPS-Koordinate Längengrad (Sprint U)
  plusCode            String? // Google Plus Code für Forststandorte (Sprint U)
  flaecheGeojson      Json? // GeoJSON Polygon für Auftragsfläche (Sprint Q017)
  telegramChatId      String? // Telegram Chat-ID für Kundenbenachrichtigung
  // KI-1: WP-Sync Merge-Strategie
  localUpdatedAt      DateTime? // Zeitstempel der letzten lokalen FM-Änderung
  wpSyncedAt          DateTime? // Zeitstempel der letzten WP-Synchronisation
  syncStatus          String?            @default("synced") // synced, local_changes, conflict
  deletedAt           DateTime? // Soft-Delete Timestamp (DSGVO Retention)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  saison              Saison?            @relation(fields: [saisonId], references: [id], onDelete: SetNull)
  gruppe              Gruppe?            @relation(fields: [gruppeId], references: [id], onDelete: SetNull)
  abnahmen            Abnahme[]
  dokumente           Dokument[]
  protokolle          Tagesprotokoll[]
  rechnungen          Rechnung[]
  lagerBewegungen     LagerBewegung[]
  maschineneinsaetze  Maschineneinsatz[]
  stundeneintraege    Stundeneintrag[]
  logs                AuftragLog[]
  angebote            Angebot[]
}

// AUDIT-LOG FÜR AUFTRÄGE (Sprint S)
model AuftragLog {
  id        String   @id @default(cuid())
  auftragId String
  auftrag   Auftrag  @relation(fields: [auftragId], references: [id], onDelete: Cascade)
  aktion    String // status_geaendert, mitarbeiter_zugewiesen, rechnung_erstellt, etc.
  von       String? // alter Wert
  nach      String? // neuer Wert
  userId    String?
  createdAt DateTime @default(now())
}

// AUFTRAG-TEMPLATES (Sprint Q031)
// Vordefinierte Vorlagen für wiederkehrende Auftragstypen
model AuftragTemplate {
  id                  String   @id @default(cuid())
  name                String   @unique // z.B. "Standardpflanzung"
  beschreibung        String? // Kurzbeschreibung wann nutzen
  typ                 String // pflanzung, kulturschutz, saatguternte, etc.
  defaultTitel        String? // Voreingestellter Titel
  defaultBeschreibung String? // Voreingestellte Aufgabenbeschreibung
  defaultFlaeche      Float? // Typische Flächengröße
  defaultBaumarten    String? // Typische Baumarten
  defaultZeitraum     String? // Typischer Zeitraum (z.B. "März-Mai")
  defaultWizardDaten  Json? // Typspezifische Voreinstellungen (pflanzverband, zauntyp, etc.)
  icon                String? // Lucide Icon Name für UI
  sortOrder           Int      @default(0) // Sortierreihenfolge
  aktiv               Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// GRUPPE
model Gruppe {
  id                 String             @id @default(cuid())
  name               String
  saisonId           String?
  gruppenfuehrerId   String?
  status             String             @default("aktiv")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  saison             Saison?            @relation(fields: [saisonId], references: [id], onDelete: SetNull)
  auftraege          Auftrag[]
  mitglieder         GruppeMitglied[]
  maschineneinsaetze Maschineneinsatz[]
  // Sprint AO: Wochenplanung
  wochenplaene       Wochenplan[]
}

model GruppeMitglied {
  id            String      @id @default(cuid())
  gruppeId      String
  mitarbeiterId String
  rolle         String      @default("mitarbeiter")
  gruppe        Gruppe      @relation(fields: [gruppeId], references: [id], onDelete: Cascade)
  mitarbeiter   Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)

  @@unique([gruppeId, mitarbeiterId])
}

// SAISON-ANMELDUNG
model SaisonAnmeldung {
  id            String      @id @default(cuid())
  saisonId      String
  mitarbeiterId String
  status        String      @default("angemeldet")
  notiz         String?
  createdAt     DateTime    @default(now())
  saison        Saison      @relation(fields: [saisonId], references: [id], onDelete: Cascade)
  mitarbeiter   Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)

  @@unique([saisonId, mitarbeiterId])
}

// LAGER (Sprint FS erweitert)
model LagerArtikel {
  id                     String              @id @default(cuid())
  name                   String
  kategorie              String              @default("material")
  einheit                String              @default("Stück")
  bestand                Float               @default(0)
  mindestbestand         Float               @default(0)
  lagerort               String?
  artikelnummer          String?
  // Sprint FS (C4-C6): Einkaufs- und Verkaufspreise
  einkaufspreis          Float?
  verkaufspreis          Float?
  // KL-2: Lieferanten-Relation
  lieferantId            String?
  lieferant              Lieferant?          @relation(fields: [lieferantId], references: [id], onDelete: SetNull)
  lieferzeit             Int? // Lieferzeit in Tagen
  // KN-1: Lieferanten-spezifische Felder
  lieferantPreis         Decimal? // Einkaufspreis beim Lieferanten
  lieferantBestellnummer String? // Artikelnummer beim Lieferanten
  deletedAt              DateTime? // Soft-Delete Timestamp (DSGVO Retention)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  bewegungen             LagerBewegung[]
  reservierungen         LagerReservierung[]
  bestellPositionen      BestellPosition[]
}

// KL-1: Lager-Reservierungslogik
model LagerReservierung {
  id           String       @id @default(cuid())
  artikelId    String
  artikel      LagerArtikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
  auftragId    String
  menge        Float
  status       String       @default("RESERVIERT") // RESERVIERT, VERBRAUCHT, ZURUECK
  verbrauchtAm DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([auftragId])
  @@index([artikelId])
}

// KL-2: Lieferanten-Stammdaten
model Lieferant {
  id        String   @id @default(cuid())
  name      String   @unique
  email     String?
  telefon   String?
  website   String?
  adresse   String?
  plz       String?
  ort       String?
  land      String?  @default("Deutschland")
  notizen   String?
  aktiv     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artikel      LagerArtikel[]
  bestellungen Bestellung[]
}

// KO-1: Bestellungen bei Lieferanten
model Bestellung {
  id           String            @id @default(cuid())
  lieferantId  String
  lieferant    Lieferant         @relation(fields: [lieferantId], references: [id])
  status       String            @default("ENTWURF") // ENTWURF/BESTELLT/GELIEFERT
  bestelldatum DateTime          @default(now())
  gesamtbetrag Decimal           @default(0)
  notizen      String?
  positionen   BestellPosition[]
  createdAt    DateTime          @default(now())
}

model BestellPosition {
  id           String       @id @default(cuid())
  bestellungId String
  bestellung   Bestellung   @relation(fields: [bestellungId], references: [id], onDelete: Cascade)
  artikelId    String
  artikel      LagerArtikel @relation(fields: [artikelId], references: [id])
  menge        Decimal
  einzelpreis  Decimal
}

// KQ-2: SyncLog für WP-Synchronisation
model SyncLog {
  id         String   @id @default(cuid())
  entityType String // Auftrag, Kunde, etc.
  entityId   String
  direction  String // WP_TO_FM / FM_TO_WP
  status     String // OK / ERROR / CONFLICT
  error      String?
  timestamp  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([timestamp])
}

model LagerBewegung {
  id            String       @id @default(cuid())
  artikelId     String
  typ           String
  menge         Float
  referenz      String?
  notiz         String?
  auftragId     String?
  mitarbeiterId String?
  createdAt     DateTime     @default(now())
  artikel       LagerArtikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
  auftrag       Auftrag?     @relation(fields: [auftragId], references: [id], onDelete: SetNull)
  mitarbeiter   Mitarbeiter? @relation(fields: [mitarbeiterId], references: [id], onDelete: SetNull)
}

// FUHRPARK
model Fahrzeug {
  id                String             @id @default(cuid())
  typ               String
  bezeichnung       String
  kennzeichen       String?
  baujahr           Int?
  status            String             @default("verfuegbar")
  tuvDatum          DateTime?
  naechsteWartung   DateTime?
  notizen           String?
  stundenBonus      Float?             @default(0) // Extra €/h bei Maschineneinsatz (Sprint K6)
  bonusBeschreibung String? // z.B. "Schwermaschinenzuschlag"
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  einsaetze         Maschineneinsatz[]
}

model Geraet {
  id              String    @id @default(cuid())
  typ             String
  bezeichnung     String
  seriennummer    String?
  status          String    @default("verfuegbar")
  naechsteWartung DateTime?
  notizen         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Wartung {
  id           String   @id @default(cuid())
  typ          String
  referenzId   String
  beschreibung String
  datum        DateTime
  kosten       Float?
  erledigt     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// LOHN & FINANZEN
model Lohneintrag {
  id            String      @id @default(cuid())
  mitarbeiterId String
  saisonId      String?
  monat         Int
  jahr          Int
  stunden       Float       @default(0)
  stundenlohn   Float
  brutto        Float       @default(0)
  netto         Float?
  ausgezahlt    Boolean     @default(false)
  ausgezahltAm  DateTime?
  notizen       String?
  createdAt     DateTime    @default(now())
  mitarbeiter   Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
}

model Vorschuss {
  id                   String      @id @default(cuid())
  mitarbeiterId        String
  betrag               Float
  datum                DateTime    @default(now())
  grund                String?
  genehmigt            Boolean     @default(false)
  zurueckgezahlt       Boolean     @default(false)
  individualBonus      Float?      @default(0) // Extra-Bonus für diese Abrechnung (Sprint K7)
  individualBonusGrund String? // Begründung (z.B. "Schichtleitung", "Erschwernis")
  createdAt            DateTime    @default(now())
  mitarbeiter          Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
}

// STUNDEN & ABWESENHEIT
model Stundeneintrag {
  id                String      @id @default(cuid())
  mitarbeiterId     String
  datum             DateTime
  stunden           Float
  auftragId         String?
  typ               String      @default("arbeit")
  notiz             String?
  genehmigt         Boolean     @default(false)
  stundenlohn       Float? // Stundenlohn zum Zeitpunkt der Erfassung
  maschinenzuschlag Float? // Maschinenbonus (Sprint K1+)
  createdAt         DateTime    @default(now())
  mitarbeiter       Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
  auftrag           Auftrag?    @relation(fields: [auftragId], references: [id], onDelete: SetNull)
}

model Abwesenheit {
  id            String      @id @default(cuid())
  mitarbeiterId String
  von           DateTime
  bis           DateTime
  typ           String
  genehmigt     Boolean     @default(false)
  notiz         String?
  createdAt     DateTime    @default(now())
  mitarbeiter   Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
}

// QUALIFIKATIONEN
model Qualifikation {
  id           String                     @id @default(cuid())
  name         String
  typ          String                     @default("zertifikat")
  beschreibung String?
  createdAt    DateTime                   @default(now())
  mitarbeiter  MitarbeiterQualifikation[]
}

model MitarbeiterQualifikation {
  id              String        @id @default(cuid())
  mitarbeiterId   String
  qualifikationId String
  erworbenAm      DateTime?
  ablaufDatum     DateTime?
  notiz           String?
  mitarbeiter     Mitarbeiter   @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
  qualifikation   Qualifikation @relation(fields: [qualifikationId], references: [id], onDelete: Cascade)
}

// SCHULUNGEN
model Schulung {
  id            String                @id @default(cuid())
  titel         String
  typ           String                @default("pflicht")
  beschreibung  String?
  datum         DateTime?
  ort           String?
  maxTeilnehmer Int?
  status        String                @default("geplant")
  createdAt     DateTime              @default(now())
  teilnehmer    MitarbeiterSchulung[]
}

model MitarbeiterSchulung {
  id              String      @id @default(cuid())
  mitarbeiterId   String
  schulungId      String
  status          String      @default("angemeldet")
  abgeschlossenAm DateTime?
  mitarbeiter     Mitarbeiter @relation(fields: [mitarbeiterId], references: [id], onDelete: Cascade)
  schulung        Schulung    @relation(fields: [schulungId], references: [id], onDelete: Cascade)

  @@unique([mitarbeiterId, schulungId])
}

// DOKUMENTE
model Dokument {
  id             String       @id @default(cuid())
  name           String
  typ            String       @default("sonstiges")
  url            String?
  nextcloudPath  String?
  auftragId      String?
  saisonId       String?
  hochgeladenVon String?
  deletedAt      DateTime? // Soft-Delete Timestamp (DSGVO Retention)
  createdAt      DateTime     @default(now())
  // Mitarbeiter-Dokumente (Sprint BQ)
  mitarbeiterId  String?
  mitarbeiter    Mitarbeiter? @relation(fields: [mitarbeiterId], references: [id])
  kategorie      String? // "a1", "sicherheitsunterweisung", "versicherung", "lohnsteuer", "vertrag", "fuehrerschein", "sonstiges"
  jahr           Int? // Jahrgang des Dokuments (z.B. 2026)
  ablaufDatum    DateTime? // für Dokumente die ablaufen (A1, Führerschein etc.)
  vertraulich    Boolean      @default(false) // nur Admin sichtbar
  groesse        Int? // Dateigröße in Bytes
  mimeType       String? // z.B. "application/pdf"
  beschreibung   String?
  auftrag        Auftrag?     @relation(fields: [auftragId], references: [id], onDelete: SetNull)
  saison         Saison?      @relation(fields: [saisonId], references: [id], onDelete: SetNull)
}

// ABNAHMEN
model Abnahme {
  id        String   @id @default(cuid())
  auftragId String
  auftrag   Auftrag  @relation(fields: [auftragId], references: [id], onDelete: Cascade)
  datum     DateTime @default(now())

  // Förster
  foersterId      String?
  foersterName    String? // Name des Försters (Freitext oder aus Kontakt)
  foersterEmail   String?
  foersterTelefon String?

  // Status-Workflow
  status String @default("offen") // offen|bestätigt|abgelehnt|mängel

  // Abnahme-Details
  notizen          String?
  abnahmeProtokoll String? // Detailliertes Abnahmeprotokoll

  // Mängel
  haengelListe Json? // Array: [{beschreibung, priorität, erledigtAm}]
  maengelFrist DateTime? // Bis wann müssen Mängel behoben sein

  // GPS Standort der Abnahme
  gpsLat Float?
  gpsLon Float?

  // Dokumentation
  fotos       Json? // Array: [{url, nextcloudPath, caption}]
  signaturUrl String? // Unterschrift Förster (Base64 oder URL)
  pdfUrl      String? // Generiertes Abnahme-Protokoll PDF

  // Auftrag-Freigabe
  rechnungFreigegeben Boolean   @default(false)
  freigegebenAm       DateTime?
  freigegebenVon      String? // userId

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// TAGESPROTOKOLL
model Tagesprotokoll {
  id          String   @id @default(cuid())
  auftragId   String
  auftrag     Auftrag  @relation(fields: [auftragId], references: [id], onDelete: Cascade)
  gruppeId    String?
  datum       DateTime
  ersteller   String   @default("")
  erstellerId String?

  // ── Arbeitszeit (Sprint BP) ───────────────────────────────────
  arbeitsbeginn String?
  arbeitsende   String?
  pauseMinuten  Int?    @default(0)

  // ── Fläche & Leistung ─────────────────────────────────────────
  flaecheBearbeitetHa Float?
  abschnitt           String?

  // ── Pflanzung Details ─────────────────────────────────────────
  gepflanztGesamt Int?
  gepflanzt       Int?
  pflanzDetails   Json?
  pflanzverband   String?
  pflanztiefe     String?

  // ── Boden & Standort ──────────────────────────────────────────
  bodenVorbereitung   String?
  bodenbeschaffenheit String?
  hangneigung         String?

  // ── Witterung ─────────────────────────────────────────────────
  witterung     String?
  temperaturMin Int?
  temperaturMax Int?
  wind          String?
  frost         Boolean? @default(false)

  // ── GPS ───────────────────────────────────────────────────────
  gpsStartLat Float?
  gpsStartLon Float?
  gpsEndLat   Float?
  gpsEndLon   Float?
  gpsTrack    Json?

  // ── Team ──────────────────────────────────────────────────────
  mitarbeiterAnzahl Int?
  mitarbeiterListe  Json?

  // ── Material & Maschinen ──────────────────────────────────────
  materialVerbraucht Json?
  maschinenEinsatz   Json?

  // ── Qualitätskontrolle ────────────────────────────────────────
  ausfaelleAnzahl     Int?     @default(0)
  ausfaelleGrund      String?
  nachpflanzungNoetig Boolean? @default(false)
  qualitaetsBewertung Int?

  // ── Protokoll & Notizen ───────────────────────────────────────
  bericht              String   @default("")
  besonderheiten       String?
  naechsteSchritte     String?
  waldbesitzerAnwesend Boolean? @default(false)
  waldbesitzerNotiz    String?

  // ── Dokumentation ─────────────────────────────────────────────
  fotos          Json?
  unterschriftGf String?

  // ── Legacy-Felder (Abwärtskompatibilität) ─────────────────────
  kommentar                 String?
  forstamt                  String?
  revier                    String?
  revierleiter              String?
  abteilung                 String?
  waldbesitzerName          String?
  zeitBeginn                DateTime?
  zeitEnde                  DateTime?
  pausezeit                 Int?
  std_einschlag             Float?
  std_handpflanzung         Float?
  stk_pflanzung             Int?
  std_zum_bohrer            Float?
  std_mit_bohrer            Float?
  stk_pflanzung_mit_bohrer  Int?
  std_freischneider         Float?
  std_motorsaege            Float?
  std_wuchshuellen          Float?
  stk_wuchshuellen          Int?
  std_netze_staebe_spiralen Float?
  stk_netze_staebe_spiralen Int?
  std_zaunbau               Float?
  stk_drahtverbinder        Int?
  lfm_zaunbau               Float?
  std_nachbesserung         Float?
  stk_nachbesserung         Int?
  std_sonstige_arbeiten     Float?

  // ── Status ────────────────────────────────────────────────────
  status        String    @default("entwurf")
  eingereichtAm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

// KONTAKTE
model Kontakt {
  id        String    @id @default(cuid())
  name      String
  typ       String    @default("sonstig")
  telefon   String?
  email     String?
  forstamt  String?
  revier    String?
  adresse   String?
  notizen   String?
  deletedAt DateTime? // Soft-Delete Timestamp (DSGVO Retention)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// MASCHINENEINSATZ (Sprint K2)
model Maschineneinsatz {
  id          String    @id @default(cuid())
  fahrzeugId  String
  fahrzeug    Fahrzeug  @relation(fields: [fahrzeugId], references: [id], onDelete: Cascade)
  gruppeId    String?
  gruppe      Gruppe?   @relation(fields: [gruppeId], references: [id], onDelete: SetNull)
  auftragId   String?
  auftrag     Auftrag?  @relation(fields: [auftragId], references: [id], onDelete: SetNull)
  vonDatum    DateTime
  bisDatum    DateTime?
  zweck       String?
  stundensatz Float? // Maschinenkosten pro Stunde (optional)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// RECHNUNGEN
model Rechnung {
  id                String             @id @default(cuid())
  auftragId         String?
  nummer            String             @unique
  betrag            Float
  mwst              Float              @default(19)
  status            String             @default("offen")
  rechnungsDatum    DateTime           @default(now())
  faelligAm         DateTime?
  pdfUrl            String?
  notizen           String?
  // Sprint BQ: Erweiterte Felder
  rabatt            Float?             @default(0) // Rabatt in Prozent (0-100)
  rabattBetrag      Float?             @default(0) // Absoluter Rabattbetrag
  rabattGrund       String?
  nettoBetrag       Float?
  bruttoBetrag      Float?
  zahlungsBedingung String?            @default("30 Tage netto")
  // Sprint GB-01: GoBD-Compliance - Unveränderlichkeits-Lock
  lockedAt          DateTime? // Wenn gesetzt: Rechnung ist gesperrt (GoBD-konform, keine Änderungen mehr möglich)
  lockedBy          String? // User-ID oder 'SYSTEM' für automatische Sperrung
  lockReason        String?            @default("GoBD-Compliance") // Grund der Sperrung
  // Sprint GB-04: GoBD 10-Jahres-Retention - Soft-Delete
  deletedAt         DateTime? // Soft-Delete Zeitstempel (GoBD: physische Löschung erst nach 10 Jahren)
  deletedBy         String? // User-ID oder 'SYSTEM_CRON' bei automatischer Löschung
  // Sprint JY: DSGVO Art. 18 - Einschränkung der Verarbeitung (statt Löschung wegen GoBD)
  gdprRestricted    Boolean            @default(false) // true = Zugriff eingeschränkt (DSGVO-Löschantrag bei GoBD-pflichtigen Daten)
  gdprRestrictedAt  DateTime? // Wann wurde die Einschränkung aktiviert
  gdprRestrictedBy  String? // User-ID oder 'SYSTEM'
  gdprRequestId     String? // Verweis auf GdprRequest
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  auftrag           Auftrag?           @relation(fields: [auftragId], references: [id], onDelete: SetNull)
  positionen        RechnungPosition[]
  auditLog          RechnungAuditLog[]
  versionen         RechnungVersion[]
  gdprRequest       GdprRequest?       @relation(fields: [gdprRequestId], references: [id])

  @@index([deletedAt]) // Index für effiziente Filterung aktiver Rechnungen
}

// RECHNUNGS-AUDIT-LOG (Sprint GB-01: GoBD-Compliance)
// Protokolliert alle Änderungen an Rechnungen für Revisionssicherheit
model RechnungAuditLog {
  id         String   @id @default(cuid())
  rechnungId String
  rechnung   Rechnung @relation(fields: [rechnungId], references: [id], onDelete: Cascade)
  action     String // 'CREATE', 'UPDATE', 'LOCK', 'UNLOCK_ATTEMPT'
  field      String? // Welches Feld geändert wurde
  oldValue   String? // Alter Wert (JSON-serialisiert)
  newValue   String? // Neuer Wert (JSON-serialisiert)
  userId     String? // Wer hat die Änderung gemacht
  userName   String? // Name des Users (für Archiv)
  ip         String? // IP-Adresse
  userAgent  String? // Browser/Client
  createdAt  DateTime @default(now())

  @@index([rechnungId])
  @@index([createdAt])
}

// RECHNUNGS-VERSIONIERUNG (Sprint GB-03: GoBD-Compliance)
// Speichert vollständige Snapshots vor jeder Änderung (solange nicht gelockt)
model RechnungVersion {
  id                 String    @id @default(cuid())
  rechnungId         String
  rechnung           Rechnung  @relation(fields: [rechnungId], references: [id], onDelete: Cascade)
  versionNummer      Int // Sequentielle Versionsnummer (1, 2, 3, ...)
  // Snapshot aller relevanten Felder zum Zeitpunkt der Version
  nummer             String
  betrag             Float
  mwst               Float
  status             String
  rechnungsDatum     DateTime
  faelligAm          DateTime?
  pdfUrl             String?
  notizen            String?
  rabatt             Float?
  rabattBetrag       Float?
  rabattGrund        String?
  nettoBetrag        Float?
  bruttoBetrag       Float?
  zahlungsBedingung  String?
  // Positionen als JSON-Snapshot
  positionenSnapshot Json? // Array aller RechnungPosition zum Zeitpunkt
  // Meta-Daten
  erstelltVon        String? // userId der Änderung
  erstelltVonName    String? // Name des Users (für Archiv)
  aenderungsgrund    String? // Optionaler Kommentar zur Änderung
  createdAt          DateTime  @default(now())

  @@unique([rechnungId, versionNummer])
  @@index([rechnungId])
  @@index([createdAt])
}

// RECHNUNGS-POSITIONEN (Sprint BQ)
model RechnungPosition {
  id              String   @id @default(cuid())
  rechnungId      String
  rechnung        Rechnung @relation(fields: [rechnungId], references: [id], onDelete: Cascade)
  beschreibung    String
  menge           Float
  einheit         String // "Stk", "ha", "Std", "lfm", "pauschal"
  preisProEinheit Float
  gesamt          Float
  protokollId     String? // Welches Protokoll hat diese Position erzeugt
  typ             String   @default("leistung") // leistung|material|fahrt
  createdAt       DateTime @default(now())
}

// LOHNABRECHNUNG (Sprint R)
model Lohnabrechnung {
  id             String      @id @default(cuid())
  mitarbeiterId  String
  mitarbeiter    Mitarbeiter @relation(fields: [mitarbeiterId], references: [id])
  saisonId       String?
  saison         Saison?     @relation(fields: [saisonId], references: [id])
  zeitraumVon    DateTime
  zeitraumBis    DateTime
  stunden        Float
  bruttoLohn     Float
  gesamtLohn     Float
  maschinenBonus Float       @default(0)
  vorschuesse    Float       @default(0)
  auszahlung     Float
  status         String      @default("erstellt")
  notizen        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// ============================================================
// WOCHENPLAN-SYSTEM (Sprint AO)
// Für alle Dienstleistungen: Pflanzung, Flächenvorbereitung, Kulturpflege,
// Kulturschutz, Saatguternte, Sonstiges
// ============================================================

model Wochenplan {
  id             String               @id @default(cuid())
  kalenderwoche  Int // KW-Nummer (1-53)
  jahr           Int // Jahr
  gruppeId       String? // Zugewiesene Gruppe
  gruppe         Gruppe?              @relation(fields: [gruppeId], references: [id])
  erstelltVon    String? // User-ID des Erstellers
  dienstleistung String? // Haupt-Dienstleistungstyp: pflanzung|flaechenvorbereitung|kulturpflege|kulturschutz|saatguternte|sonstiges
  gruppenleiter  String? // Name des Gruppenführers für Unterschrift
  status         String               @default("entwurf") // entwurf, freigegeben, abgeschlossen
  notizen        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  positionen     WochenplanPosition[]

  @@unique([kalenderwoche, jahr, gruppeId])
}

model WochenplanPosition {
  id                 String     @id @default(cuid())
  wochenplanId       String
  wochenplan         Wochenplan @relation(fields: [wochenplanId], references: [id], onDelete: Cascade)
  dienstleistungstyp String // pflanzung, flaechenvorbereitung, kulturpflege, kulturschutz, saatguternte, sonstiges
  tag                Int? // Wochentag: 1=Mo, 2=Di, 3=Mi, 4=Do, 5=Fr
  datum              DateTime?
  auftragId          String? // Optionale Verknüpfung mit Auftrag
  aufgabe            String? // Aufgabenbeschreibung für die Position
  einheit            String? // Einheit: kg, Stück, ha
  erledigt           Boolean    @default(false)
  status             String     @default("geplant") // geplant, in_arbeit, abgeschlossen
  notizen            String?

  // ── Gemeinsame Felder ──────────────────────────────────────
  flaeche     String? // Flächen-Bezeichnung / Waldstück
  gpsPosition String? // GPS-Koordinate als "lat,lon" String (alias gpsKoordinaten)
  treffpunkt  String? // Treffpunkt-Beschreibung oder GPS

  // ── Pflanzung-spezifisch ───────────────────────────────────
  baumart    String?
  stueckzahl Int?

  // ── Saatguternte-spezifisch ────────────────────────────────
  herkunftscode String? // Herkunftscode z.B. "06 NRW-818-07"
  zielkg        Float? // Ziel in Kilogramm (alias zielMenge)
  gesammelteKg  Float?  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// SYSTEM-KONFIGURATION (Sprint P)
model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// KJ-2: Pflanzverband-Konfiguration (dynamisch aus DB statt hard-coded)
model PflanzverbandConfig {
  id          String   @id @default(cuid())
  name        String   @unique // z.B. "Quincunx 1,0×0,75m"
  abstandX    Float // Abstand in Reihe (m)
  abstandY    Float // Abstand zwischen Reihen (m)
  muster      String   @default("GLEICH") // QUINCUNX, GLEICH, ALTERNIEREND
  svgPreview  String? // SVG-Code für Vorschau
  stueckProHa Int? // Berechnete Stückzahl pro Hektar
  aktiv       Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// KK-1: Kunden-Content für Blog/Bewertungen
// Workflow: Auftragsabschluss → Einwilligung anfragen → Content generieren → Freigabe → Veröffentlichung
model KundenContent {
  id        String @id @default(cuid())
  auftragId String @unique

  // Einwilligungs-Status
  einwilligungStatus String    @default("AUSSTEHEND") // AUSSTEHEND, ERTEILT, ABGELEHNT
  einwilligungDatum  DateTime?

  // Content
  contentVorschlag String? // KI-generierter Markdown-Text
  contentFinal     String? // Nach Bearbeitung finaler Text

  // Freigaben
  tomekFreigabe      Boolean   @default(false)
  tomekFreigabeDatum DateTime?
  kundeFreigabe      Boolean   @default(false)
  kundeFreigabeDatum DateTime?

  // Veröffentlichung
  veroeffentlicht   Boolean   @default(false)
  wpPostId          String? // WordPress Post-ID nach Veröffentlichung
  wpPostUrl         String? // URL des veröffentlichten Posts
  veroeffentlichtAm DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ANGEBOTE (Sprint T + FQ)
model Angebot {
  id                  String    @id @default(cuid())
  nummer              String?   @unique
  auftragId           String?
  auftrag             Auftrag?  @relation(fields: [auftragId], references: [id])
  waldbesitzerName    String?
  waldbesitzerEmail   String?
  flaeche_ha          Float?
  baumanzahl          Int?
  preisProBaum        Float?
  stundenSchaetzung   Float?
  gesamtpreis         Float?
  beschreibung        String?
  status              String    @default("entwurf") // entwurf, versendet, angenommen, abgelehnt
  gueltigBis          DateTime?
  notizen             String?
  // Sprint FQ (B5): Ersteller für Berechtigungsprüfung
  createdById         String?
  // Sprint FQ (B6): Kundenbudget als optionales Feld
  budgetKunde         Float?
  // Sprint FQ (B1): Kalkulations-Transparenz
  kalkulationsModus   String? // "flaeche" | "stueck" | "stunden"
  kalkulationsDetails String? // JSON mit Berechnungsdetails
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ============================================================
// SAATGUTERNTE MODUL (Sprint W)
// ============================================================

// Registerquellen (z.B. Bayern, NW-FVA, Rheinland-Pfalz)
model ErnteRegisterQuelle {
  id             String    @id @default(cuid())
  name           String
  kuerzel        String    @unique
  bundeslaender  String[]
  baseUrl        String?
  crawlUrl       String?
  loginRequired  Boolean   @default(false)
  crawlStatus    String    @default("idle")
  letzterCrawl   DateTime?
  naechsterCrawl DateTime?
  crawlLog       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  credential RegisterCredential?
  flaechen   RegisterFlaeche[]
}

model RegisterCredential {
  id            String   @id @default(cuid())
  quelleId      String   @unique
  encryptedUser String
  encryptedPass String
  iv            String
  authTag       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  quelle ErnteRegisterQuelle @relation(fields: [quelleId], references: [id], onDelete: Cascade)
}

model RegisterFlaeche {
  id                    String    @id @default(cuid())
  quelleId              String
  registerNr            String
  bundesland            String
  baumart               String
  baumartWiss           String?
  baumartCode           String?
  kategorie             String?
  ausgangsmaterial      String?
  herkunftsgebiet       String?
  herkunftCode          String?
  latDez                Float?
  lonDez                Float?
  koordinatenRaw        String?
  flaecheHa             Float?
  flaecheRedHa          Float?
  hoeheVon              Int?
  hoeheBis              Int?
  forstamt              String?
  revier                String?
  besitzart             String?
  eigentumsart          String?
  landkreis             String?
  wuchsbezirk           String?
  zulaessigeFlaechen    String?
  zulassungVon          DateTime?
  zulassungBis          DateTime?
  zulassungBisText      String?
  zugelassen            Boolean   @default(true)
  erstesJahr            Int?
  ansprechpartner       String?
  ansprechpartnerTel    String?
  ansprechpartnerEmail  String?
  hoheitlicheStelle     String?
  genetischUntersucht   Boolean   @default(false)
  sonderherkunft        Boolean   @default(false)
  alter                 String?
  verwendungszweck      String?
  verkehrsbeschraenkung Boolean   @default(false)
  quelleUrl             String?
  rohdaten              Json?
  datenstand            String?
  letzteAktualisierung  DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  quelle      ErnteRegisterQuelle @relation(fields: [quelleId], references: [id])
  profil      FlaechenProfil?
  wetterDaten WetterSnapshot[]
  medien      MediaZuordnung[]
  einsaetze   ErnteEinsatz[]

  @@unique([quelleId, registerNr])
}

model FlaechenProfil {
  id               String    @id @default(cuid())
  flaecheId        String    @unique
  status           String    @default("ungeprüft")
  bewertung        Int?
  notizen          String?
  letzteInspektion DateTime?
  naechsteErnte    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  flaeche RegisterFlaeche @relation(fields: [flaecheId], references: [id], onDelete: Cascade)
  ernten  Ernte[]
}

model Ernte {
  id            String   @id @default(cuid())
  profilId      String
  saison        Int
  datum         DateTime
  baumart       String
  mengeKgGesamt Float?
  notizen       String?
  exportiert    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profil     FlaechenProfil  @relation(fields: [profilId], references: [id])
  positionen ErntePosition[]
}

model ErntePosition {
  id          String   @id @default(cuid())
  ernteId     String
  sammlerName String
  datum       DateTime
  mengeKg     Float
  stunden     Float?
  notizen     String?
  createdAt   DateTime @default(now())

  ernte Ernte @relation(fields: [ernteId], references: [id], onDelete: Cascade)
}

model WetterSnapshot {
  id             String   @id @default(cuid())
  flaecheId      String
  datum          DateTime
  jahr           Int?
  tempMinAvgC    Float?
  tempMaxAvgC    Float?
  tempMinC       Float?
  tempMaxC       Float?
  niederschlagMm Float?
  frosttage      Int?
  hitzetage      Int?
  regentage      Int?
  monatlichDaten Json?
  datenQuelle    String   @default("open-meteo")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  flaeche RegisterFlaeche @relation(fields: [flaecheId], references: [id], onDelete: Cascade)

  @@unique([flaecheId, jahr])
}

// MEDIEN & DROHNEN (Sprint AB)
model MediaZuordnung {
  id            String    @id @default(cuid())
  flaecheId     String?
  nextcloudPath String
  dateiname     String
  typ           String // bild, video
  datum         DateTime?
  mission       String?
  vorschauUrl   String?
  createdAt     DateTime  @default(now())

  flaeche RegisterFlaeche? @relation(fields: [flaecheId], references: [id], onDelete: SetNull)
}

// ===== SAATGUTERNTE — Erweitertes System (Sprint AC) =====

model ErntePerson {
  id            String   @id @default(cuid())
  name          String   @unique
  nationalitaet String?
  stundenlohn   Float    @default(12.5)
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  arbeitszeitEintraege    SammlerArbeitszeit[]
  ernteLeistungen         ErnteLeistung[]
  gruppenMitgliedschaften ErnteGruppeMitglied[]
}

model ErnteSaison {
  id             String   @id @default(cuid())
  jahr           Int      @unique
  gruppenFuehrer String?
  notizen        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  einsaetze ErnteEinsatz[]
  anfragen  Ernteanfrage[]
  gruppen   ErnteGruppe[]
}

model ErnteEinsatz {
  id              String   @id @default(cuid())
  saisonId        String
  gruppeId        String?
  datum           DateTime
  registerNr      String?
  flaecheId       String?
  baumart         String
  forstamt        String?
  eigentuemer     String?
  ort             String?
  ansprechpartner String?
  bldh            String?
  zeitVorOrt      Float?
  herkunft        String?
  notizen         String?
  // Sprint AH: GPS-Track als JSON-Array [{lat, lon, timestamp}]
  gpsTrack        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  saison        ErnteSaison          @relation(fields: [saisonId], references: [id])
  gruppe        ErnteGruppe?         @relation(fields: [gruppeId], references: [id])
  flaeche       RegisterFlaeche?     @relation(fields: [flaecheId], references: [id])
  leistungen    ErnteLeistung[]
  sammlerZeiten SammlerArbeitszeit[]
}

// ===== SPRINT AD: Baumschulen · Ernteanfragen · Gruppen =====

model Baumschule {
  id               String    @id @default(cuid())
  name             String    @unique
  ort              String?
  bundesland       String?
  ansprechpartner  String?
  email            String?
  telefon          String?
  notizen          String?
  aktiv            Boolean   @default(true)
  // Sprint AJ: Baumschul-Authentifizierung
  loginToken       String?   @unique // Login-Link-Token (einmalig, zeitlich begrenzt)
  loginTokenExpiry DateTime? // Ablaufzeit des Login-Tokens
  userId           String?   @unique // Verknüpfter User-Account (Rolle: baumschule)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  anfragen    Ernteanfrage[]
  preislisten BaumschulPreisliste[]
  user        User?                 @relation(fields: [userId], references: [id])
}

// Sprint AI: Preislistenverwaltung für Baumschulen
model BaumschulPreisliste {
  id           String     @id @default(cuid())
  baumschuleId String
  baumschule   Baumschule @relation(fields: [baumschuleId], references: [id], onDelete: Cascade)
  baumart      String // z.B. "Eiche", "Buche", "Fichte"
  preis        Float // Preis in Euro
  einheit      String     @default("kg") // kg, Stück, Bündel
  saison       String? // z.B. "2025", "2025/2026"
  aktiv        Boolean    @default(true)
  notizen      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Ernteanfrage {
  id           String    @id @default(cuid())
  baumschuleId String
  saisonId     String?
  baumart      String
  herkunft     String?
  zielmenge    Float
  gesammelteKg Float     @default(0)
  deadline     DateTime?
  status       String    @default("offen")
  notizen      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  herkunftCode       String? // z.B. "06", "07", "818 07"
  herkunftName       String? // z.B. "Nordrhein-Westfalen Tiefland" (optional)
  sonderherkunft     Boolean @default(false)
  sonderherkunftCode String? // Code der DKV-Sonderherkunft, z.B. "DKV-818-001"
  sonderherkunftName String? // Name der Sonderherkunft

  baumschule Baumschule   @relation(fields: [baumschuleId], references: [id])
  saison     ErnteSaison? @relation(fields: [saisonId], references: [id])
}

model ErnteGruppe {
  id                 String   @id @default(cuid())
  saisonId           String
  name               String
  gruppenfuehrerName String?
  stundenlohnGF      Float?   @default(17.0)
  notizen            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  saison     ErnteSaison           @relation(fields: [saisonId], references: [id])
  mitglieder ErnteGruppeMitglied[]
  einsaetze  ErnteEinsatz[]
}

model ErnteGruppeMitglied {
  id        String   @id @default(cuid())
  gruppeId  String
  personId  String
  rolle     String   @default("sammler")
  createdAt DateTime @default(now())

  gruppe ErnteGruppe @relation(fields: [gruppeId], references: [id])
  person ErntePerson @relation(fields: [personId], references: [id])

  @@unique([gruppeId, personId])
}

model ErnteLeistung {
  id          String   @id @default(cuid())
  einsatzId   String
  personId    String
  gesammeltKg Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  einsatz ErnteEinsatz @relation(fields: [einsatzId], references: [id])
  person  ErntePerson  @relation(fields: [personId], references: [id])

  @@unique([einsatzId, personId])
}

model SammlerArbeitszeit {
  id            String    @id @default(cuid())
  personId      String
  einsatzId     String?
  datum         DateTime
  arbeitsBeginn DateTime?
  arbeitsEnde   DateTime?
  pause         Float?
  stunden       Float?
  kommentar     String?
  stundenlohn   Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  person  ErntePerson   @relation(fields: [personId], references: [id])
  einsatz ErnteEinsatz? @relation(fields: [einsatzId], references: [id])

  @@unique([personId, datum])
}

// ============================================================
// TELEGRAM BENACHRICHTIGUNGEN (Sprint — Telegram Bot)
// Waldbesitzer erhalten Status-Updates via Telegram
// ============================================================

model TelegramRegistrierung {
  id           String   @id @default(cuid())
  chatId       String   @unique
  waldbesitzer String
  auftragId    String?
  aktiv        Boolean  @default(true)
  createdAt    DateTime @default(now())
}

// FEEDBACK-SYSTEM (Sprint Feedback)
model FeedbackEintrag {
  id        String   @id @default(cuid())
  typ       String // bug | wunsch | frage
  text      String
  seite     String?
  nutzer    String?
  createdAt DateTime @default(now())
}

// ============================================================
// KG-1: DSGVO CONSENT SYSTEM
// Verwaltet Einwilligungen für KI-Features
// ============================================================

model UserConsent {
  id          String    @id @default(cuid())
  userId      String
  consentType String // KI_VERARBEITUNG, FOTO_AUSWERTUNG, MARKETING
  grantedAt   DateTime  @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, consentType])
  @@index([userId])
}

// ============================================================
// DSGVO RETENTION: Lösch-Log für Hard-Delete Dokumentation
// Protokolliert alle unwiederbringlichen Löschungen (Art. 17 DSGVO)
// ============================================================

model DeletionLog {
  id            String   @id @default(cuid())
  entityType    String // User, Mitarbeiter, Auftrag, Dokument, etc.
  entityId      String // Original-ID des gelöschten Datensatzes
  entitySummary String? // Anonymisierte Zusammenfassung (z.B. "Mitarbeiter #123")
  deletedBy     String? // userId oder "SYSTEM_CRON"
  reason        String   @default("RETENTION_POLICY") // RETENTION_POLICY, GDPR_REQUEST, MANUAL
  retentionDays Int? // Nach wie vielen Tagen Soft-Delete erfolgte Hard-Delete
  metadata      Json? // Zusätzliche Metadaten (ohne personenbezogene Daten!)
  createdAt     DateTime @default(now())

  @@index([entityType])
  @@index([createdAt])
}

// ============================================================
// COLD STORAGE ARCHIVIERUNG (IMPL-RP-05)
// Für Daten >3 Jahre: aus aktiven Tabellen ins Archiv verschieben
// Reduziert aktive DB-Last, erfüllt GoBD-Aufbewahrungspflichten
// ============================================================

// Archivierte Aufträge (abgeschlossene Aufträge >3 Jahre alt)
model ArchivedAuftrag {
  id                String   @id // Original-ID beibehalten
  originalCreatedAt DateTime // Ursprüngliches Erstellungsdatum
  archivedAt        DateTime @default(now())
  archiveReason     String   @default("COLD_STORAGE_3Y")

  // Snapshot aller relevanten Auftragsdaten
  titel               String
  typ                 String
  status              String
  beschreibung        String?
  flaeche_ha          Float?
  standort            String?
  bundesland          String?
  waldbesitzer        String?
  waldbesitzerEmail   String?
  waldbesitzerTelefon String?
  baumarten           String?
  zeitraum            String?
  notizen             String?
  nummer              String?
  startDatum          DateTime?
  endDatum            DateTime?
  lat                 Float?
  lng                 Float?

  // Vollständige Metadaten als JSON-Snapshot
  fullSnapshot Json // Kompletter Auftrag mit allen Relationen

  @@index([originalCreatedAt])
  @@index([archivedAt])
}

// Archivierte Tagesprotokolle (>3 Jahre alt)
model ArchivedTagesprotokoll {
  id                String   @id // Original-ID beibehalten
  auftragId         String // Referenz zum (ggf. archivierten) Auftrag
  originalCreatedAt DateTime // Ursprüngliches Erstellungsdatum
  archivedAt        DateTime @default(now())
  archiveReason     String   @default("COLD_STORAGE_3Y")

  // Wichtige Felder für schnelle Suche
  datum     DateTime
  ersteller String?
  gruppeId  String?
  status    String

  // Vollständiger Snapshot
  fullSnapshot Json // Komplettes Protokoll mit allen Details

  @@index([auftragId])
  @@index([datum])
  @@index([archivedAt])
}

// Archivierte Rechnungen (GoBD: 10 Jahre Aufbewahrung, ab Jahr 4 im Archiv)
model ArchivedRechnung {
  id                String   @id // Original-ID beibehalten
  originalCreatedAt DateTime // Ursprüngliches Erstellungsdatum
  archivedAt        DateTime @default(now())
  archiveReason     String   @default("COLD_STORAGE_3Y")

  // Pflichtfelder für GoBD-Compliance (schneller Zugriff)
  nummer         String
  auftragId      String?
  betrag         Float
  bruttoBetrag   Float?
  mwst           Float
  status         String
  rechnungsDatum DateTime

  // Vollständiger GoBD-konformer Snapshot
  fullSnapshot Json // Komplette Rechnung mit Positionen + AuditLog

  @@index([nummer])
  @@index([rechnungsDatum])
  @@index([archivedAt])
}

// Archivierte Dokumente (>3 Jahre alt, Dateien bleiben in Nextcloud)
model ArchivedDokument {
  id                String   @id // Original-ID beibehalten
  originalCreatedAt DateTime // Ursprüngliches Erstellungsdatum
  archivedAt        DateTime @default(now())
  archiveReason     String   @default("COLD_STORAGE_3Y")

  // Wichtige Referenzen
  name          String
  typ           String
  nextcloudPath String? // Pfad bleibt für Zugriff erhalten
  auftragId     String?
  mitarbeiterId String?

  // Vollständiger Snapshot
  fullSnapshot Json

  @@index([auftragId])
  @@index([archivedAt])
}

// Archivierte Stunden- und Lohneinträge (>3 Jahre, nach Steuer-Aufbewahrungspflicht)
model ArchivedLohndaten {
  id                String   @id @default(cuid())
  entityType        String // Stundeneintrag, Lohneintrag, Lohnabrechnung
  entityId          String // Original-ID
  mitarbeiterId     String
  originalCreatedAt DateTime
  archivedAt        DateTime @default(now())
  archiveReason     String   @default("COLD_STORAGE_3Y")

  // Schnellzugriff-Felder
  zeitraum String? // z.B. "2022-Q1" oder "2022-03"
  betrag   Float? // Bruttolohn oder Stundensumme

  // Vollständiger Snapshot
  fullSnapshot Json

  @@index([mitarbeiterId])
  @@index([zeitraum])
  @@index([archivedAt])
}

// Archivierungs-Log: Dokumentiert jeden Archivierungsvorgang
model ArchiveLog {
  id          String    @id @default(cuid())
  runId       String // Eindeutige ID pro Cron-Lauf
  entityType  String // ArchivedAuftrag, ArchivedRechnung, etc.
  entityCount Int // Anzahl archivierter Datensätze
  cutoffDate  DateTime // Stichtag (createdAt < cutoffDate)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  status      String    @default("RUNNING") // RUNNING, SUCCESS, FAILED
  error       String?

  @@index([runId])
  @@index([startedAt])
}

// ============================================================
// DSGVO ART. 18: EINSCHRÄNKUNG DER VERARBEITUNG (Sprint JY)
// Statt Löschung bei GoBD-pflichtigen Daten → Zugriffssperre
// ============================================================

model GdprRequest {
  id                 String     @id @default(cuid())
  // Antragsteller-Informationen
  requesterName      String // Name des Betroffenen
  requesterEmail     String // E-Mail für Kommunikation
  requesterType      String     @default("KUNDE") // KUNDE, MITARBEITER, EXTERN
  // Antragsdetails
  requestType        String // LOESCHUNG, AUSKUNFT, EINSCHRAENKUNG, BERICHTIGUNG, WIDERSPRUCH
  requestReason      String? // Begründung des Antragstellers
  // Betroffene Daten
  affectedEntities   Json? // Array: [{entityType: "Rechnung", entityIds: ["abc", "def"]}]
  // Status-Workflow
  status             String     @default("EINGEGANGEN") // EINGEGANGEN, IN_PRUEFUNG, UMGESETZT, ABGELEHNT, ARCHIVIERT
  statusHistory      Json? // Array: [{status, changedAt, changedBy, reason}]
  // Bearbeitung
  assignedTo         String? // User-ID des zuständigen Admins
  internalNotes      String? // Interne Bearbeitungsnotizen
  // Entscheidung
  decision           String? // STATTGEGEBEN, TEILWEISE, ABGELEHNT
  decisionReason     String? // Begründung der Entscheidung (Pflicht bei Ablehnung)
  decisionAt         DateTime?
  decisionBy         String? // User-ID
  // DSGVO-Compliance: GoBD-Konflikt-Handling
  gobdConflict       Boolean    @default(false) // true wenn Löschung wegen GoBD nicht möglich
  restrictionApplied Boolean    @default(false) // true wenn Einschränkung statt Löschung angewandt
  // SLA: 30 Tage Bearbeitungsfrist (DSGVO Art. 12 Abs. 3)
  receivedAt         DateTime   @default(now())
  dueAt              DateTime? // Frist (receivedAt + 30 Tage, +60 bei Komplexität)
  completedAt        DateTime?
  // Dokumentation
  correspondenceLog  Json? // Array: [{date, direction, subject, content}]
  // Relations
  rechnungen         Rechnung[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([status])
  @@index([requesterEmail])
  @@index([receivedAt])
  @@index([dueAt])
}

// Audit-Log für DSGVO-Anfragen (separate Tabelle für Revisionssicherheit)
model GdprRequestAuditLog {
  id              String   @id @default(cuid())
  requestId       String
  action          String // CREATED, STATUS_CHANGED, RESTRICTION_APPLIED, DECISION_MADE, etc.
  field           String?
  oldValue        String?
  newValue        String?
  performedBy     String? // User-ID
  performedByName String? // Name für Archiv
  ipAddress       String?
  createdAt       DateTime @default(now())

  @@index([requestId])
  @@index([createdAt])
}

// ============================================================
// VERTRAGSVERSIONIERUNG: AGB-AKZEPTANZ (Sprint KB CV-02/03)
// Immutable Log: Speichert jede AGB-Akzeptanz revisionssicher
// DSGVO Art. 7: Nachweis der Einwilligung
// ============================================================

model UserAgreement {
  id              String   @id @default(cuid())
  userId          String // Verknüpfung zum User
  // Vertragsdetails
  agreementType   String // AGB, DATENSCHUTZ, KI_ANNEX, NEWSLETTER, etc.
  agreementVersion String // Versionsstring z.B. "1.0.0", "2024-03-15"
  // Akzeptanz-Zeitpunkt
  acceptedAt      DateTime @default(now())
  // Forensische Daten (DSGVO Art. 7 Nachweis)
  ipAddress       String? // IP-Adresse des Nutzers
  userAgent       String? // Browser/Client User-Agent
  deviceInfo      String? // Zusätzliche Geräteinformationen (optional)
  // Kontext
  acceptedVia     String   @default("WEB") // WEB, APP, API
  sessionId       String? // Session-ID zum Zeitpunkt der Akzeptanz
  // Referenz zum Vertragstext (Snapshot-URL oder Hash)
  documentHash    String? // SHA-256 Hash des akzeptierten Dokuments
  documentUrl     String? // URL zum archivierten Vertragstext

  // Relation zum User
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // IMMUTABLE: Diese Tabelle hat kein updatedAt - Einträge werden nie geändert!
  // Widerruf = neuer Eintrag in separater Tabelle oder agreementType "WIDERRUF_*"

  @@index([userId])
  @@index([agreementType])
  @@index([acceptedAt])
  @@index([agreementVersion])
}

// ============================================================
// ACCESS LOGGING FÜR PERSONENBEZOGENE DATEN (Sprint DA-29)
// DSGVO-konforme Protokollierung aller Zugriffe auf PD
// Retention: 90 Tage (automatische Löschung via Cron)
// ============================================================

model PdAccessLog {
  id         String   @id @default(cuid())
  userId     String?  // User-ID des Zugreifenden (null bei unauthentifiziert)
  userName   String?  // Name des Users (für Archiv, falls User gelöscht)
  resource   String   // Betroffene Ressource: USER_PROFILE, GPS_DATA, TIME_ENTRIES, INVOICE, MITARBEITER
  resourceId String?  // ID des spezifischen Datensatzes (optional)
  action     String   // READ, WRITE, DELETE, EXPORT, BULK_READ
  ip         String?  // IP-Adresse des Zugreifenden
  userAgent  String?  // Browser/Client
  endpoint   String?  // API-Endpoint z.B. "/api/users/123"
  method     String?  // HTTP-Methode: GET, POST, PUT, DELETE
  statusCode Int?     // HTTP-Statuscode der Antwort
  metadata   Json?    // Zusätzliche Daten (z.B. Filter-Parameter bei Bulk-Read)
  createdAt  DateTime @default(now())
  // Retention: Einträge >90 Tage werden via Cron gelöscht
  // Kein updatedAt - Einträge sind immutable

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@index([ip])
}

// ============================================================
// TENANT DATENEXPORT (Sprint OE IMPL-CHURN-05)
// DSGVO Art. 20 Datenportabilität
// Download-Link gültig für 7 Tage
// ============================================================

enum ExportStatus {
  pending      // Export wurde angefordert
  processing   // ZIP wird generiert
  completed    // Fertig, Download verfügbar
  expired      // 7 Tage abgelaufen
  failed       // Fehler bei der Generierung
}

model ExportRequest {
  id          String       @id @default(cuid())
  tenantId    String       // Tenant dessen Daten exportiert werden
  requestedBy String       // User-ID der anfordernden Person
  token       String       @unique @default(cuid()) // Sicherer Download-Token
  status      ExportStatus @default(pending)
  // Statistiken
  fileSize    Int?         // Dateigröße in Bytes
  recordCount Json?        // Anzahl Records pro Typ {auftraege: 50, protokolle: 200, ...}
  // Zeitstempel
  createdAt   DateTime     @default(now())
  startedAt   DateTime?    // Wann begann die Verarbeitung
  completedAt DateTime?    // Wann wurde der Export fertiggestellt
  expiresAt   DateTime     // Download-Link Ablaufdatum (createdAt + 7 Tage)
  downloadedAt DateTime?   // Wann wurde der Download abgerufen
  // Fehlerbehandlung
  errorMessage String?     // Fehlermeldung bei status=failed
  // Inhalt (als JSON referenziert für Sicherheit)
  exportedTypes String[]   @default([]) // ["auftraege", "protokolle", "rechnungen", ...]
  
  @@index([tenantId])
  @@index([token])
  @@index([status])
  @@index([expiresAt])
}

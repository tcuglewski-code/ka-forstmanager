generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        String   @default("mitarbeiter")
  avatar      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    Session[]
  mitarbeiter Mitarbeiter?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Mitarbeiter {
  id              String    @id @default(cuid())
  userId          String?   @unique
  vorname         String
  nachname        String
  email           String?
  telefon         String?
  mobil           String?
  adresse         String?
  plz             String?
  ort             String?
  geburtsdatum    DateTime?
  eintrittsdatum  DateTime?
  austrittsdatum  DateTime?
  rolle           String    @default("mitarbeiter")
  qualifikationen String?
  fuehrerschein   String?
  notfallkontakt  String?
  notfalltelefon  String?
  bankname        String?
  iban            String?
  stundenlohn     Float?
  status          String    @default("aktiv")
  notizen         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User?     @relation(fields: [userId], references: [id])
}

model Saison {
  id           String    @id @default(cuid())
  name         String
  typ          String    @default("pflanzung")
  status       String    @default("planung")
  startDatum   DateTime?
  endDatum     DateTime?
  beschreibung String?
  ziel         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  primaryColor String   @default("#2C3A1C")
  domain       String?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  entityName String
  userId     String?
  metadata   String?
  createdAt  DateTime @default(now())
}
